<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <TextView
        android:id="@+id/tvNombre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textStyle="bold|italic"
        android:textSize="16sp"
        android:text="Nombre"
        app:layout_constraintBottom_toBottomOf="@+id/etNombre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/etNombre" />

    <TextView
        android:id="@+id/tvNombre2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textStyle="bold|italic"
        android:textSize="16sp"
        android:text="Ciudad"
        app:layout_constraintBottom_toBottomOf="@+id/etCiudad"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/etCiudad" />

    <ImageView
        android:id="@+id/ivEscudo"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@drawable/okc" />

    <!-- Campo para la abreviatura -->
    <EditText
        android:id="@+id/etAbreviatura"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        android:hint="OKC"
        android:inputType="textCapCharacters|textNoSuggestions"
        android:maxLength="3"
        app:layout_constraintEnd_toStartOf="@id/ivEscudo"
        app:layout_constraintStart_toEndOf="@+id/tvAbreviatura"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Campo para el nombre -->
    <EditText
        android:id="@+id/etNombre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        android:hint="Thunder"
        app:layout_constraintEnd_toStartOf="@id/ivEscudo"
        app:layout_constraintStart_toStartOf="@+id/etAbreviatura"
        app:layout_constraintTop_toBottomOf="@id/etAbreviatura" />

    <!-- Campo para el nombre completo -->
    <EditText
        android:id="@+id/etNombreCompleto"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="32dp"
        android:hint="Oklahoma City Thunder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/etNombre"
        app:layout_constraintTop_toBottomOf="@+id/ivEscudo" />

    <!-- Campo para la ciudad -->
    <EditText
        android:id="@+id/etCiudad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="32dp"
        android:hint="Oklahoma City"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/etNombreCompleto"
        app:layout_constraintTop_toBottomOf="@id/etNombreCompleto" />

    <!-- Spinner para la división -->
    <Spinner
        android:id="@+id/spinnerDivision"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="@+id/etCiudad"
        app:layout_constraintTop_toBottomOf="@id/etCiudad"
        app:layout_constraintWidth_percent="0.7" />

    <!-- Spinner para la conferencia -->
    <Spinner
        android:id="@+id/spinnerConferencia"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="@+id/spinnerDivision"
        app:layout_constraintTop_toBottomOf="@id/spinnerDivision" />

    <!-- Checkbox para favorito -->
    <CheckBox
        android:id="@+id/cbFavorito"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Favorito"
        app:layout_constraintStart_toStartOf="@+id/spinnerConferencia"
        app:layout_constraintTop_toBottomOf="@id/spinnerConferencia" />

    <!-- Botón para añadir equipo -->
    <Button
        android:id="@+id/btnAnadirEquipo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Modificar Equipo"
        app:layout_constraintStart_toStartOf="@+id/cbFavorito"
        app:layout_constraintTop_toBottomOf="@id/cbFavorito" />

    <TextView
        android:id="@+id/tvAbreviatura"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textStyle="bold|italic"
        android:textSize="16sp"
        android:text="Código"
        app:layout_constraintBottom_toBottomOf="@+id/etAbreviatura"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/etAbreviatura" />


</androidx.constraintlayout.widget.ConstraintLayout>